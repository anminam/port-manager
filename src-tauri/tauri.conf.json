{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Port Manager",
  "version": "2.0.2",
  "identifier": "com.anminam.port-manager",
  "build": {
    "frontendDist": "../dist-html",
    "beforeBuildCommand": "",
    "beforeDevCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Port Manager",
        "width": 900,
        "height": 700,
        "minWidth": 700,
        "minHeight": 500,
        "titleBarStyle": "Overlay",
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": null,
      "signingIdentity": null
    },
    "category": "DeveloperTool"
  }
}
